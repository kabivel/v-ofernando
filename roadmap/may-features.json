[
  { id:"559478", title:"PowerPoint: Create and edit images with the model of your choice", product:"Microsoft Copilot (Microsoft 365)", status:"Launched", date:"May 2026",
    short:"Choose your preferred image model — OpenAI GPT Image, Black Forest Lab Flux, Microsoft MAI-Image and more — when creating or editing images with Copilot in PowerPoint.",
    desc:"You can now choose your preferred image model including OpenAI's GPT Image, Black Forest Lab's Flux and Microsoft's MAI-Image and more, for smart, dynamic selection when creating or editing images with Copilot in PowerPoint, or when generating a new presentation or page." },
  { id:"553214", title:"Microsoft 365: Modernized Access Denied web experience", product:"Microsoft 365", status:"Launched", date:"May 2026",
    short:"Refreshed Access Denied page with Fluent design, animations, and clearer messaging across SharePoint, OneDrive, and meeting recordings.",
    desc:"We're introducing a visual refresh of the Access Denied web experience across Microsoft 365, where users can request access to files, sites, and meeting recordings. This update features a modern Fluent design with new illustrations, animations, and clearer messaging to help users quickly gain confidence and seamlessly continue their collaboration." },
  { id:"559261", title:"Microsoft Purview: Data Lifecycle Management - DLM Retention support for Microsoft Teams call logs", product:"Microsoft Purview", status:"Launched", date:"May 2026",
    short:"Retention policies for Teams call logs (CDR) so customers can comply with regulatory mandates while improving user experience.",
    desc:"Microsoft Teams stores call logs in several persistent locations (CDR logs). Until now they were retained indefinitely. With DLM retention for Teams call logs, organizations can ensure Teams remains compliant with regulatory requirements that mandate maximum retention periods, while also supporting evolving features and business needs." },
  { id:"557716", title:"Microsoft Teams: Teams Phone user multi-line", product:"Microsoft Teams", status:"Launched", date:"May 2026",
    short:"Assign up to 10 phone numbers to a single user across Teams desktop, mobile and devices.",
    desc:"Teams Phone user multi-line gives callers more flexibility and control by allowing administrators to assign up to 10 phone numbers to a single user. With full support across Teams desktop, Teams mobile, and Teams devices, users can seamlessly make and receive calls from multiple numbers without switching accounts or hardware." },
  { id:"559418", title:"Outlook: Copilot provides coaching feedback in chat as you draft, edit and format emails", product:"Outlook", status:"Rolling out", date:"May 2026",
    short:"Copilot offers coaching suggestions on email drafts via chat and can apply changes directly to the message.",
    desc:"Copilot now provides coaching feedback on email drafts via chat and can apply suggestions directly to your message in Outlook. Users have the option to choose which suggestions are applied, and Copilot updates your email in place." },
  { id:"558254", title:"Microsoft Teams: Improved copy and paste support for @mentions and shared contacts", product:"Microsoft Teams", status:"Rolling out", date:"May 2026",
    short:"@mentions and shared contacts are preserved when copy/pasting messages — Teams intelligently keeps the link or falls back to plain text.",
    desc:"Microsoft Teams preserves @mentions and shared contacts when you copy and paste messages in chats and channels. Instead of defaulting to plain text, Teams intelligently displays an @mention, shared contact, or plain text based on where the content is pasted, reducing manual rework." },
  { id:"552595", title:"Outlook: Draft, edit and format emails conversationally with Copilot in Outlook for Mac", product:"Outlook", status:"Rolling out", date:"May 2026",
    short:"Copilot now works side by side with users in Outlook for Mac to draft, refine, and format emails conversationally.",
    desc:"In Outlook, Copilot now works side by side with users to draft, refine, and format emails conversationally, powered by the same agentic capabilities available in Word, Excel, and PowerPoint." },
  { id:"559605", title:"Microsoft Teams: Improved organization for muted and meeting chats", product:"Microsoft Teams", status:"Rolling out", date:"May 2026",
    short:"Built-in sections automatically group muted chats and (optionally) meeting chats to reduce clutter.",
    desc:"Microsoft Teams automatically organizes your chats with new built-in sections that help reduce clutter and keep conversations easy to find. Muted chats (on by default) are grouped together in a dedicated area, while meeting chats (off by default) can be collected into a single section for quick access. You're always in control — each section can be turned on or off based on your preferences." },
  { id:"559611", title:"Microsoft Teams: Annotations on Teams Single Window Sharing on macOS", product:"Microsoft Teams", status:"Rolling out", date:"May 2026",
    short:"Presenters can share a single window on Mac and let participants annotate without exposing the entire desktop.",
    desc:"Presenters can now share a single application window and enable participants to annotate directly on top of that content, without exposing their entire desktop. This means cleaner presentations, protected privacy, and more engaging discussions across training sessions, workshops, and client meetings." },
  { id:"561493", title:"Microsoft Teams: Upload custom backgrounds for Teams events", product:"Microsoft Teams", status:"In development", date:"June 2026",
    short:"Organizers/presenters with production-tools access can upload custom backgrounds for Teams events ('Manage what attendees see').",
    desc:"Organizers and presenters who have access to production tools can now upload custom backgrounds in the 'Manage what attendees see' experience for Teams events. This enhancement allows organizations to display their brand identity by replacing the default backgrounds with company logos, event-specific artwork, or themed visuals. Requires a Teams Premium license. Available on Teams for Windows desktop and Mac desktop." },
  { id:"561549", title:"Microsoft Teams: Teams room builder in the Pro Management portal", product:"Microsoft Teams", status:"In development", date:"June 2026",
    short:"User-friendly tool in the Teams Rooms Pro Management portal to design, configure and standardize Teams Rooms spaces.",
    desc:"The Teams room builder is a user-friendly, visually engaging tool to help IT managers design and configure Teams Rooms traditional, signature, and flex meeting spaces. This feature, available in the Teams Rooms Pro Management portal, enables faster design, standards creation, and rollout. With a variety of equipment options and helpful criteria filters, device and license selection and purchase is simplified. Available with Teams Rooms Pro." },
  { id:"561485", title:"Microsoft Forms: Copilot in Forms — US Government clouds", product:"Forms", status:"In development", date:"September 2026",
    short:"End-to-end Copilot AI assistance for Microsoft Forms is being enabled in Government Cloud environments (GCC, GCC High, DoD).",
    desc:"Copilot in Forms is being enabled for Microsoft Forms in Government Cloud environments, bringing end-to-end AI assistance to forms — from creating a form, to refining and sending, to analyzing results. This rollout includes Draft with Copilot, Distribution and monitoring, Copilot Insights, and on-canvas Copilot features such as Rewrite question, Continue writing, Answer explanations and more." },
  { id:"561330", title:"Microsoft 365: Cross-tenant Message Recall in Exchange Online", product:"Microsoft 365", status:"In development", date:"August 2026",
    short:"Recall messages sent to other organizations that add your tenant to their recall allow list.",
    desc:"We're enhancing the Exchange Online Message Recall feature to add support for cross-tenant recalls. Today, you can recall messages only within your organization. Cross-tenant recall will let you recall messages sent to other organizations that add your tenant to their recall allow list." },
  { id:"557190", title:"Microsoft Purview: Data Loss Prevention — File Quarantine action for SharePoint/OneDrive", product:"Microsoft Purview", status:"In development", date:"June 2026",
    short:"DLP can now automatically move triggering files to a restricted, admin-defined quarantine location in SharePoint/OneDrive.",
    desc:"File Quarantine action in Microsoft Purview DLP for SharePoint and OneDrive enables stronger, immediate protection for sensitive data. When a DLP policy is triggered, the File Quarantine action automatically moves the file to a restricted, admin-controlled & defined quarantine location — instantly removing access for all users while preserving the file for review and investigation." },
  { id:"560547", title:"Microsoft Teams: Report external users for security concerns", product:"Microsoft Teams", status:"In development", date:"June 2026",
    short:"Users can report suspicious external users directly within Teams; reports surface in the Teams admin center.",
    desc:"Users can now report suspicious external users directly within Teams, alongside existing block actions. Reports are surfaced in the Teams admin center, giving admins visibility into potentially risky interactions and enabling them to investigate and take appropriate actions. This enhancement helps organizations respond faster to phishing, impersonation, and other external threats while leveraging end-user signals as an additional layer of protection." }
]
